# TubeNote environment template.
# Copy to `.env` and fill only the providers/features you use.

# ---------------------------------------------------------------------------
# LLM providers
# ---------------------------------------------------------------------------
# Default provider/model can be overridden from backend/config.yaml.
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-v4-flash

# DeepSeek is used by the current RAG UI by default.
# DEEPSEEK_API_KEY=

# Optional alternative providers.
# GOOGLE_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# YouTube cookies
# ---------------------------------------------------------------------------
# Optional. Useful when YouTube requires authentication/bot checks.
# By default the app auto-detects an installed browser (chrome/edge/firefox/
# brave/...) that has valid YouTube login cookies — nothing to set here.
# Only set this to force a specific browser (skips auto-detect):
# YT_COOKIES_BROWSER=chrome
# Fallback for headless environments without a local browser:
# YT_COOKIES_DIR=cookies
# YT_COOKIES_PATH=cookies/primary.txt

# ---------------------------------------------------------------------------
# Local services / retrieval
# ---------------------------------------------------------------------------
# SEARXNG_URL=http://localhost:8888

# Embedding defaults are in backend/config.yaml.
# EMBEDDING_PROVIDER=huggingface
# EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_DEVICE=cpu

# Optional Hugging Face token for higher Hub rate limits.
# HF_TOKEN=

# ---------------------------------------------------------------------------
# TTS model overrides
# ---------------------------------------------------------------------------
# TTS_MODEL=M5
# OMNIVOICE_MODEL=k2-fsa/OmniVoice

# ---------------------------------------------------------------------------
# Dev server overrides used by run.sh
# ---------------------------------------------------------------------------
# BACKEND_HOST=127.0.0.1
# BACKEND_PORT=8010
# NEXT_PUBLIC_API=http://localhost:8010

# Verbose debug logging for skipped/cached steps.
# TUBENOTE_VERBOSE=1
