# Provider mặc định (override config.yaml)
# LLM_PROVIDER=google
# LLM_MODEL=gemini-2.5-flash

# --- API keys (chỉ set cái nào bạn dùng) ---
# GOOGLE_API_KEY=...
# OPENAI_API_KEY=...
# ANTHROPIC_API_KEY=...

# --- Cookies YouTube ---
# (a) Rotation qua folder (khuyến nghị)
YT_COOKIES_DIR=cookies
# (b) Hoặc 1 file cụ thể
# YT_COOKIES_PATH=F:\Link2Slide\cookies\primary.txt
