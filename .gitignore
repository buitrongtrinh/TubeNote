# ==============================================================================
# Secrets — TUYỆT ĐỐI KHÔNG commit
# ==============================================================================
.env
.env.*
!.env.example

# Cookies YouTube — chứa session login cá nhân
cookies/*.txt
!cookies/.gitkeep

# Streamlit secrets
.streamlit/secrets.toml

# ==============================================================================
# Runtime output — code tự tạo (os.makedirs)
# ==============================================================================
output/
chroma_langchain_db/             # legacy vector store từ notebook era

# ==============================================================================
# Vietsub / TTS experiments — chưa ready để push
# ==============================================================================
TTS_model_demo/
translate_sub_demo/

# Dev test files / one-off scripts
tmp/

# ==============================================================================
# Media binaries (preventive — Whisper download audio, vd .m4a)
# ==============================================================================
*.wav
*.mp3
*.m4a
*.mp4
*.mkv

# ==============================================================================
# Python
# ==============================================================================
__pycache__/
*.pyc
.venv/

# ==============================================================================
# SearXNG runtime (commit chỉ settings.yml; uwsgi/limiter là runtime)
# ==============================================================================
searxng_config/uwsgi.ini
searxng_config/limiter.toml

# ==============================================================================
# OS / IDE noise (preventive)
# ==============================================================================
.DS_Store
Thumbs.db
.vscode/
.idea/

# ==============================================================================
# Claude / AI tooling
# ==============================================================================
.claude/
