# ==============================================================================
# Secrets — TUYỆT ĐỐI KHÔNG commit
# ==============================================================================
.env
.env.*
!.env.example

# Cookies YouTube — chứa session login cá nhân
cookies/*.txt
!cookies/.gitkeep

# Streamlit secrets
.streamlit/secrets.toml

# ==============================================================================
# Runtime output — code tự tạo (os.makedirs)
# ==============================================================================
# Lưu ý: gitignore KHÔNG hỗ trợ comment inline — comment phải nằm dòng riêng.
data/
# Tên cũ (output/, chroma_langchain_db/): giữ phòng máy khác còn artefact.
output/
chroma_langchain_db/

# ==============================================================================
# Scratch / experiments — chưa ready để push
# ==============================================================================
scratch/
TTS_model_demo/
*.ipynb
*.log

# ==============================================================================
# Frontend (Next.js)
# ==============================================================================
frontend/node_modules/
frontend/.next/
translate_sub_demo/

# Dev test files / one-off scripts
tmp/

# ==============================================================================
# Media binaries (preventive — Whisper download audio, vd .m4a)
# ==============================================================================
*.wav
*.mp3
*.m4a
*.mp4
*.mkv
# Ngoại lệ: voice preset gốc của 2 TTS engine — asset bắt buộc để dropdown
# giọng hoạt động trên máy người clone repo (config.yaml tham chiếu tới).
# Voice trích từ video người dùng lúc runtime nằm ở data/voice_clones/ (đã
# ignore qua data/), KHÔNG nằm ở đây.
!voice_clones/**/*.wav

# ==============================================================================
# Python
# ==============================================================================
__pycache__/
*.pyc
.venv/

# ==============================================================================
# SearXNG runtime (commit chỉ settings.yml; uwsgi/limiter là runtime)
# ==============================================================================
searxng_config/uwsgi.ini
searxng_config/limiter.toml

# ==============================================================================
# OS / IDE noise (preventive)
# ==============================================================================
.DS_Store
Thumbs.db
.vscode/
.idea/

# ==============================================================================
# Claude / AI tooling
# ==============================================================================
.claude/
.agents/
.codex/
